# ─── Supabase ────────────────────────────────────────────────────────────────
# Project URL and anon key from Supabase: Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key — SERVER ONLY, never exposed to the browser.
# Project Settings → API → service_role secret
SUPABASE_SERVICE_ROLE_KEY=

# ─── Mapbox ──────────────────────────────────────────────────────────────────
# Public token for the field map (Phase 2). Browser-exposed by design.
NEXT_PUBLIC_MAPBOX_TOKEN=

# ─── Anthropic ───────────────────────────────────────────────────────────────
# Powers the Markets sell/hold outlook (Phase 3). SERVER ONLY.
ANTHROPIC_API_KEY=

# ─── Market data (API Ninjas) ────────────────────────────────────────────────
# Futures commodity prices + history. SERVER ONLY — never exposed to the browser.
# Free tier is 15-min delayed and rotates available commodities weekly.
# https://api-ninjas.com/api/commodityprice
API_NINJAS_KEY=
