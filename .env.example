# ─── Supabase ────────────────────────────────────────────────────────────────
# Project URL and anon key from Supabase: Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key — SERVER ONLY, never exposed to the browser.
# Project Settings → API → service_role secret
SUPABASE_SERVICE_ROLE_KEY=

# ─── Mapbox ──────────────────────────────────────────────────────────────────
# Public token for the field map (Phase 2). Browser-exposed by design.
NEXT_PUBLIC_MAPBOX_TOKEN=

# ─── Anthropic ───────────────────────────────────────────────────────────────
# Powers the Markets sell/hold outlook (Phase 3). SERVER ONLY.
ANTHROPIC_API_KEY=

# ─── Market data (API Ninjas) ────────────────────────────────────────────────
# Futures commodity prices + history. SERVER ONLY — never exposed to the browser.
# Free tier is 15-min delayed and rotates available commodities weekly.
# https://api-ninjas.com/api/commodityprice
API_NINJAS_KEY=

# ─── USDA NASS Quick Stats (Outlook Engine — Phase 6) ────────────────────────
# Crop progress / condition / yield / production data. SERVER ONLY. Free key:
# https://quickstats.nass.usda.gov/api  — request a key, it arrives by email.
# Attribution required: products using this data are not endorsed by NASS.
USDA_NASS_KEY=

# ─── USDA FAS Export Sales (Outlook — Demand bucket) ─────────────────────────
# Weekly export sales (+ China) + daily flash sales. SERVER ONLY. Free key from
# api.data.gov: https://open.fas.usda.gov  (sent via X-Api-Key header).
USDA_FAS_KEY=

# ─── EIA (Outlook — Demand bucket: ethanol grind) ────────────────────────────
# Weekly U.S. fuel-ethanol production. SERVER ONLY. Free key:
# https://www.eia.gov/opendata/register.php
EIA_API_KEY=

# ─── Cron / scheduled jobs ───────────────────────────────────────────────────
# Shared secret gating /api/cron/refresh and /api/alerts/evaluate. Vercel Cron
# sends it as `Authorization: Bearer <secret>`. REQUIRED IN PRODUCTION — with no
# secret set the endpoints refuse (503) in prod; only local dev leaves them open.
# Generate: openssl rand -hex 32
CRON_SECRET=
